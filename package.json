{
  "name": "staffpass-ocr-hub",
  "version": "1.3.1",
  "type": "commonjs",
  "author": "StaffPass",
  "license": "MIT",
  "description": "StaffPass Local OCR Hub — process staff ID and pass documents with AI-powered OCR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node tests/run.js",
    "download-model": "python sidecar/download_model.py",
    "prepare": "husky",
    "rebuild": "electron-builder install-app-deps",
    "dist": "npm run rebuild && electron-builder --win",
    "dist:dir": "npm run rebuild && electron-builder --win --dir"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "husky": "^9.1.7",
    "mocha": "^10.4.0"
  },
  "build": {
    "appId": "com.staffpass.ocr-hub",
    "productName": "StaffPass OCR Hub",
    "directories": {
      "output": "dist_installer"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "database.js",
      "sidecar_bridge.js",
      "index.html",
      "index.css",
      "sidecar/**/*",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "sidecar/",
        "to": "sidecar/",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": true
    },
    "publish": {
      "provider": "github",
      "owner": "prasairaul-del",
      "repo": "StaffPass-OCR-Hub"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StaffPass OCR Hub",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "allowElevation": true
    }
  }
}
