{
  "name": "staffpass-ocr-hub",
  "version": "1.4.0",
  "type": "commonjs",
  "author": "StaffPass",
  "license": "MIT",
  "description": "StaffPass Local OCR Hub - process staff ID and pass documents with AI-powered OCR",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "electron tests/run.js",
    "download-model": "python sidecar/download_model.py",
    "prepare": "husky",
    "rebuild": "electron-builder install-app-deps",
    "check-signing": "node scripts/check-signing.js",
    "validate:release-config": "node scripts/validate-release.js --mode config",
    "validate:release": "node scripts/validate-release.js --mode release",
    "validate:smoke": "node scripts/validate-release.js --mode smoke",
    "mobile:doctor": "npm --prefix mobile run doctor",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "mobile:test": "npm --prefix mobile test",
    "mobile:android:apk": "npm --prefix mobile run build:android:apk",
    "mobile:android:aab": "npm --prefix mobile run build:android:aab",
    "dist:smoke": "npm run rebuild && electron-builder --win --dir",
    "dist:installer:unsigned": "npm run rebuild && electron-builder --win --publish never -c.win.signAndEditExecutable=false",
    "dist:release": "npm run check-signing && npm run rebuild && electron-builder --win",
    "dist": "npm run dist:release",
    "dist:dir": "npm run dist:smoke"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^40.9.3",
    "electron-builder": "^26.15.0",
    "husky": "^9.1.7",
    "mocha": "^11.7.6"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  },
  "build": {
    "appId": "com.staffpass.ocr-hub",
    "productName": "StaffPass OCR Hub",
    "directories": {
      "output": "dist_installer"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "database.js",
      "sidecar_bridge.js",
      "index.html",
      "index.css",
      "sidecar/**/*",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "sidecar/",
        "to": "sidecar/",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": true
    },
    "publish": {
      "provider": "github",
      "owner": "prasairaul-del",
      "repo": "StaffPass-OCR-Hub",
      "releaseType": "draft"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StaffPass OCR Hub",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "allowElevation": true
    }
  },
  "allowScripts": {
    "better-sqlite3@12.10.0": true,
    "electron@40.9.3": true,
    "electron-winstaller@5.4.0": true
  }
}
