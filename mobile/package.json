{
  "name": "staffpass-ocr-hub-mobile",
  "version": "1.4.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "doctor": "npx expo-doctor",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/lib/*.test.ts",
    "lint": "eslint .",
    "build:android:apk": "npx eas-cli@latest build -p android --profile preview-apk",
    "build:android:aab": "npx eas-cli@latest build -p android --profile production-aab"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "expo": "~56.0.9",
    "expo-constants": "^56.0.17",
    "expo-document-picker": "^56.0.4",
    "expo-file-system": "^56.0.7",
    "expo-font": "~56.0.5",
    "expo-image": "^56.0.10",
    "expo-image-picker": "^56.0.16",
    "expo-linking": "^56.0.13",
    "expo-router": "^56.2.9",
    "expo-sharing": "^56.0.16",
    "expo-sqlite": "^56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "~19.2.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~56.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3"
  },
  "eslintConfig": {
    "extends": "expo"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@react-native-ml-kit/text-recognition"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
