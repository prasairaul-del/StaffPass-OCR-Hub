{
  "expo": {
    "name": "StaffPass OCR Hub",
    "slug": "staffpass-ocr-hub-mobile",
    "version": "1.4.0",
    "orientation": "portrait",
    "scheme": "staffpass",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.staffpass.ocrhub.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow StaffPass OCR Hub to capture staff documents for local review.",
          "photosPermission": "Allow StaffPass OCR Hub to import staff document images for local review."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "152a5cc5-b7ee-41cc-b73d-b73b2c992c97"
      }
    },
    "owner": "raul99"
  }
}
